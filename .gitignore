# === Proprietary — NEVER commit ===
# Terrain's labeling pipeline + corpus harvest tooling + boundary
# data are commercial moats. The verdict engine ships in the binary;
# the infrastructure that produced its calibration does NOT. If a
# fork has Terrain's source, they should not get Terrain's corpus
# or the tools that built it. Stripped from history 2026-05-16 via
# git filter-repo; gitignored here to prevent re-adding.

# internal/docs/ — internal-only architecture, release plans, product
# notes, and roadmap material. The two parity YAMLs that the
# terrain-parity-gate binary reads are explicitly un-ignored so the
# binary still builds and tests from a fresh clone.
internal/docs/
!internal/docs/release/
!internal/docs/release/parity/
!internal/docs/release/parity/**

cmd/internal/terrain-corpus/
cmd/internal/terrain-precision/
scripts/clone-ai-corpus.sh
scripts/discover-ai-repos.sh
scripts/expand-ai-corpus.sh
scripts/harvest-blocklist.txt
scripts/label-boundary-validation.sh
scripts/overnight-ai-corpus.sh
scripts/prep-boundary-validation.sh
scripts/process-ai-corpus.sh
scripts/reclone-and-harvest-ai.sh
scripts/resume-boundary-rescan.sh
scripts/run-ai-corpus-analysis.sh
scripts/stream-ai-corpus.sh
scripts/stream-harvest-ai.sh
scripts/stream-rescan-boundaries.sh
# Internal release/parity tracking — enumerates planning artifacts and
# PR numbers; not part of the public distribution.
scripts/parity-lift.py
# Corpus-validation pipeline (Claude/OpenAI labeling, phase replay, regression
# precision) — operates on tier-4/ inputs and outputs. Same calibration-
# infrastructure carveout as the harvest tooling above.
scripts/aggregate_validation.py
scripts/discover-gitlab-ai.sh
scripts/phase_b1_self_consistency.py
scripts/phase_b2_truncation.py
scripts/phase_b3_ext_framing.py
scripts/phase_b3_stylistic_bias.py
scripts/phase_b5_cluster_bootstrap.py
scripts/regression_precision.py
scripts/replay_a5_severity_demote.py
scripts/replay_phase_a.py
scripts/validate_corpus_claude.py
scripts/validate_corpus_openai_check.py
scripts/validate_detectors_claude.py
scripts/validate_recall_claude.py
tier-4/
.terrain/


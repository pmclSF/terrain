# === npm publish exclusions (defense-in-depth) ===
# The package.json "files" field is the primary allowlist.
# This file provides a safety net against accidental inclusion.

# Go source (not part of npm package)
internal/
cmd/
go.mod
go.sum
.goreleaser.yaml
Makefile

# Test and fixture infrastructure
test/
tests/
benchmarks/
fixtures/
*.test.js
*.spec.js
jest.config.js
playwright.config.js

# Development config
.github/
.husky/
.eslintrc*
.prettierrc*
.editorconfig
commitlint.config.cjs
tsconfig.json

# Documentation (shipped separately, not in npm package)
docs/
CLAUDE.md
DESIGN.md
CONTRIBUTING.md
CHANGELOG.md

# Extension source (separate distribution)
extension/

# Example/demo files
examples/

# Scripts (dev-only)
scripts/

# CI helpers
ci/

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs and temp
*.log
npm-debug.log*
tmp/
temp/
*.tmp
*.backup

# Generated output
artifacts/
reports/
coverage/
dist/

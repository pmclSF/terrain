# Canary set — hand-curated PRs from app-shaped AI repos used to
# measure UFPP (useful findings per PR) and suppression rate weekly
# during cycle-2 build. Per cycle-2-master-plan.md "Pilot contact
# during build (not after)" — re-run weekly; track week-over-week
# changes.
#
# Each entry is one PR. Use GitHub URLs so the runner can fetch the
# PR's base + head commit pair. Aim for 15-25 entries spanning:
#   - Multiple frameworks (langchain / llamaindex / vertical agents)
#   - PR sizes (single-file fix → multi-file refactor)
#   - Change types (prompt edits, model swaps, schema bumps, deps,
#     new features)
#   - Detector targets (each gate-tier detector should have ≥3 PRs
#     where it could legitimately fire)
#
# Copy this file to canary-set.yaml and replace the placeholders.

schema_version: 1
entries:
  # Slot 1: prompt-template change in a production agent repo.
  - id: canary-001
    pr_url: https://github.com/owner/repo/pull/123
    pr_title: "Refactor system prompt for clarity"
    expected_detectors:
      - aiPromptVersioning
      - aiSafetyEvalMissing
    notes: |
      Change touches prompts/system.md. Expect aiPromptVersioning to
      fire if no version marker present.

  # Slot 2: model deprecation handoff.
  - id: canary-002
    pr_url: https://github.com/owner/repo/pull/456
    pr_title: "Bump openai client to v2"
    expected_detectors:
      - aiModelDeprecationRisk
      - depsDriftRisk
    notes: |
      Touches package.json AND model_config.py. Two detectors.

  # ... add 13-23 more entries.
